DATABASE_URL="postgresql://postgres:postgres@localhost:5433/tosino?schema=public"
JWT_SECRET="change-me-in-production-use-long-random"
JWT_REFRESH_SECRET="change-me-refresh-secret"
API_PORT=4001
# nginx 등 리버스 프록시 1대 기본값 1. 여러 단이면 그만큼 숫자 증가
# TRUST_PROXY_HOPS=1
# 브라우저에서 /uploads 이미지·웹훅 URL 등 (접두사 /api 없음; /webhooks, /uploads 는 루트)
PUBLIC_API_URL="http://localhost:4001"
# 운영 예 (nginx apex): 공개 URL 은 스킴+호스트만, /api 붙이지 않음
# PUBLIC_API_URL="https://nexus001.vip"
# 프론트: apps/*/.env.production 에 NEXT_PUBLIC_API_URL=https://nexus001.vip/api
# 로컬 dev: NEXT_PUBLIC_API_URL=http://localhost:4001/api
# 공개 bootstrap ?host= 매칭: demo 플랫폼에 도메인이 있어야 함. 비어 있으면 404.
# SEED_PLATFORM_HOSTS=nexus001.vip,www.nexus001.vip
# 솔루션 공지 팝업(부트스트랩). 기본 켜짐. 끄려면 false
# ANNOUNCEMENT_MODAL_PUBLISH=true
# 업로드 디렉터리 (기본: apps/api/uploads)
# UPLOAD_DIR="/var/tosino/uploads"
REDIS_URL="redis://127.0.0.1:6379"
# 주기 ODDS 스냅샷 (모든 플랫폼). 비우거나 off/false 이면 비활성.
# ODDS_SYNC_CRON="*/5 * * * *"
PAYMENT_WEBHOOK_SECRET="shared-secret-with-payment-server"
# 설정 시 ?port= 미리보기 bootstrap/sports-odds 에 동일 값을 previewSecret 로 전달해야 함
# PREVIEW_BOOTSTRAP_SECRET=""
# ── OddsHost 스포츠 API 프록시 (Nest: GET /api/public/oddshost/*)
# 벤더는 허용 outbound IP 기준. 이 API 프로세스가 그 IP에서 나가야 함.
# 가이드: https://www.oddshost.com/api-guide (PRE-MATCH / IN-PLAY url 문서에 나온 전체 URL 사용)
#
# ODDSHOST_KEY
#   플랜 인증키(문자열). 저장소·슬랙에 평문으로 올리지 말고 서버/시크릿 매니저에만 둘 것.
#
# ODDSHOST_TEMPLATE_* (한 줄 전체 URL)
#   가이드에 적힌 호출 주소를 복사한 뒤, 아래만 플레이스홀더로 바꿉니다(이름 고정, 순서 무관).
#   {key}      → 인증키 자리 (서버가 ODDSHOST_KEY 로 치환·URL 인코딩)
#   {sport}    → 종목 id (쿼리 sport= 값)
#   {game_id}  → 라이브 게임 상세용 경기 id (목록 템플릿에는 보통 없음)
# 예시 형태만 참고(실제 호스트·경로는 가이드 원문으로 교체):
#   ODDSHOST_TEMPLATE_INPLAY_LIST="https://YOUR_GUIDE_HOST/inplay_list.php?sport={sport}&auth={key}"
#   ODDSHOST_TEMPLATE_INPLAY_GAME="https://YOUR_GUIDE_HOST/inplay_game.php?sport={sport}&game_id={game_id}&auth={key}"
#   ODDSHOST_TEMPLATE_PREMATCH="https://YOUR_GUIDE_HOST/prematch.php?sport={sport}&auth={key}"
#
# ODDSHOST_PROXY_SECRET
#   운영(NODE_ENV=production)에서는 필수. 솔루션 웹 API 테스트 탭이 쿼리 oddshostSecret 로 동일 값을 넘김.
#   비우면: production 에서 /public/oddshost/* 전부 403, 그 외 환경에서는 로컬 테스트용으로만 허용.
# ODDSHOST_PROXY_SECRET=""
# ODDSHOST_KEY=""
# ODDSHOST_TEMPLATE_INPLAY_LIST=""
# ODDSHOST_TEMPLATE_INPLAY_GAME=""
# ODDSHOST_TEMPLATE_PREMATCH=""
# Vinus Gaming 라이브카지노 (5자 에이전트 키; 콜백은 authKey 검증 안 함)
# VINUS_AGENT_KEY=""
# 테스트: authenticate·balance·bet·bet-win·win·win-add·cancel 만 스텁(메모리).
# sports-reserve / sports-order / sports-confirm / sports-bet / sports-bet-change / sports-win 은
# 항상 DB(원장·CasinoVinusTx·예약)에 저장 — 실연동과 동일 코드 경로.
# 운영에서는 끌 것
# VINUS_STUB_AUTHENTICATE=false
# VINUS_STUB_USER_ID: DB User.id(cuid) 또는 loginId — 스텁 authenticate·check21이 동일한 행을 찾음
# VINUS_STUB_USER_ID="stub-user-dev"
# VINUS_STUB_USERNAME="stub_login"
# VINUS_STUB_NICKNAME="StubUser"
# VINUS_STUB_BALANCE="100000"
# (선택) 로컬 스모크 스크립트가 authKey 헤더를 붙일 때만 사용
# VINUS_AUTH_KEY=""
# VINUS_GAME_BASE_URL="https://game.vinus-gaming.com"
# VINUS_INFO_BASE_URL="https://info.vinus-gaming.com"
# 콜백 등록 URL 예: {PUBLIC_API_URL}/webhooks/vinus
# 로컬에서 벤더 테스트 페이지 쓰려면 cloudflared 로 HTTPS 노출:
#   ./scripts/cloudflared-api-tunnel.sh
# 상세: docs/vinus-callback-tunnel.md
# 관리자 전용 프록시: GET /integrations/vinus/branch-balance, transaction-detail, transaction-history
# 로컬 콜백 스모크: API 기동 후 apps/api 에서
#   pnpm run vinus:callback-smoke   … authenticate 단일
#   pnpm run vinus:flows-smoke      … 심리스(bet→win→confirm) + 트랜스퍼(bet-win transfer Y)

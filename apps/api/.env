DATABASE_URL="postgresql://postgres:postgres@localhost:5433/tosino?schema=public"
JWT_SECRET="change-me-in-production-use-long-random"
JWT_REFRESH_SECRET="change-me-refresh-secret"
API_PORT=4001
PUBLIC_API_URL="http://localhost:4001"
REDIS_URL="redis://127.0.0.1:6379"
PAYMENT_WEBHOOK_SECRET="shared-secret-with-payment-server"
# Vinus 콜백/런처 테스트 (play-game 호출 시 에이전트 키는 실제 값 권장)
VINUS_AGENT_KEY="ta125"
VINUS_AUTH_KEY="local-test-callback-auth"
# 벤더 authenticate 테스트용 (운영 전 false 로)
VINUS_STUB_AUTHENTICATE=true

# ── OddsHost 스포츠 (GET /api/public/oddshost/* , 스냅샷: sports-live / sports-prematch)
# 가이드의 IN-PLAY·PRE-MATCH URL 전체를 붙이고, 인증키·sport·game_id 자리만 {key} {sport} {game_id} 로 바꿔서 아래에 넣음.
# 운영 서버: ODDSHOST_PROXY_SECRET 는 반드시 긴 랜덤 문자열로 설정. 인증키는 여기에 넣지 말고 배포 환경에서만 주입 권장.
ODDSHOST_PROXY_SECRET=
ODDSHOST_KEY=
ODDSHOST_TEMPLATE_INPLAY_LIST=
ODDSHOST_TEMPLATE_INPLAY_GAME=
ODDSHOST_TEMPLATE_PREMATCH=

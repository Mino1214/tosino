# 로컬 개발 (next dev) — .env.local 에 복사 후 수정
NEXT_PUBLIC_API_URL=http://localhost:4001/api
# 로컬에선 끄거나 생략 (true 이면 http://localhost:3002/api 로 가서 404)
# NEXT_PUBLIC_USE_SAME_ORIGIN_API=

# IP 로만 접속하는데 DB 에는 nexus001.vip 만 등록된 경우
# NEXT_PUBLIC_PLATFORM_DOMAIN=nexus001.vip

# 스포츠 탭 OddsHost 프록시 — apps/api 의 ODDSHOST_PROXY_SECRET 과 동일 문자열 (빌드에 포함됨)
# NEXT_PUBLIC_ODDSHOST_PROXY_SECRET=
